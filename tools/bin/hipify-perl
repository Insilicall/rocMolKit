# CUDA Kernel Launch Syntax
sub transformKernelLaunch {
    no warnings qw/uninitialized/;
    my $k = 0;

    $k += s{([a-zA-Z_0-9:]+(?:\s*<[^>]+>)?)\s*<<<\s*(.+?)\s*>>>\s*(\(\s*\)|\()}{do {
        my ($f, $c, $p) = ($1, $2, $3);
        my (@a, $d, $cur);
        foreach my $s (split //, $c) {
            if ($s =~ /[\(\[\<]/) { $d++ } elsif ($s =~ /[\)\]\>]/) { $d-- }
            if ($s eq ',' && $d == 0) { push @a, $cur; $cur = '' } else { $cur .= $s }
        } push @a, $cur;
        for my $i (0 .. $#a) { my $v = $a[$i]; $v =~ s/^\s+|\s+$//g; $v = '0' if $v eq ''; $a[$i] = $v; }
        push @a, ('0', '0', '0');
        for my $i (0..1) { $a[$i] = "dim3($a[$i])" unless $a[$i] =~ /^dim3\b/; }
        $f = "HIP_KERNEL_NAME($f)" if $f =~ /</;
        my $res = "hipLaunchKernelGGL($f, $a[0], $a[1], $a[2], $a[3]" . ($p =~ /\)/ ? ")" : ", ");
        $res;
    }}gexs;

    if ($k) { $ft{'kernel_launch'} += $k; }
}

sub transformCubNamespace {
    s/using\s*namespace\s*cub/using namespace hipcub/g;
    s/\bcub::\b/hipcub::/g;
}

sub transformHostFunctions {
    my $process_args = sub {
        my ($f, $args_str, $argIdx, $actionType, $cast) = @_;
        my $args_inner = substr($args_str, 1, -1);
        my (@a, $d, $cur);
        foreach my $s (split //, $args_inner) {
            if ($s =~ /[\(\[\<\{]/) { $d++ } elsif ($s =~ /[\)\]\>\}]/) { $d-- }
            if ($s eq ',' && $d == 0) { push @a, $cur; $cur = '' } else { $cur .= $s }
        } push @a, $cur;
        if (defined $a[$argIdx]) {
            my $v = $a[$argIdx]; $v =~ s/^\s+|\s+$//g;
            if ($actionType == 0 || $actionType == 1) {
                $a[$argIdx] = "$cast($v)" unless index($v, $cast) == 0;
            } elsif ($actionType == 2) {
                splice(@a, $argIdx, 1);
            }
        }
        return "$f(" . join(',', @a) . ")";
    };

    foreach $func (
        "hipMemcpyToSymbol",
        "hipMemcpyToSymbolAsync"
    )
    {
        s{\b($func)\s*(\((?:[^()]+|(?2))*\))}{ $process_args->($1, $2, 0, 0, "HIP_SYMBOL") }ges;
    }
    foreach $func (
        "hipGetSymbolAddress",
        "hipGetSymbolSize",
        "hipGetTextureReference",
        "hipGraphMemcpyNodeSetParamsToSymbol",
        "hipMemcpyFromSymbol",
        "hipMemcpyFromSymbolAsync"
    )
    {
        s{\b($func)\s*(\((?:[^()]+|(?2))*\))}{ $process_args->($1, $2, 1, 0, "HIP_SYMBOL") }ges;
    }
    foreach $func (
        "hipFuncSetAttribute",
        "hipFuncSetCacheConfig",
        "hipFuncSetSharedMemConfig",
        "hipLaunchCooperativeKernel",
        "hipLaunchKernel"
    )
    {
        s{\b($func)\s*(\((?:[^()]+|(?2))*\))}{ $process_args->($1, $2, 0, 1, "reinterpret_cast<const void*>") }ges;
    }
    foreach $func (
        "hipFuncGetAttributes"
    )
    {
        s{\b($func)\s*(\((?:[^()]+|(?2))*\))}{ $process_args->($1, $2, 1, 1, "reinterpret_cast<const void*>") }ges;
    }
    foreach $func (
        "hipGraphExecMemcpyNodeSetParamsToSymbol",
        "hipGraphMemcpyNodeSetParamsFromSymbol"
    )
    {
        s{\b($func)\s*(\((?:[^()]+|(?2))*\))}{ $process_args->($1, $2, 2, 0, "HIP_SYMBOL") }ges;
    }
    foreach $func (
        "hipModuleOccupancyMaxPotentialBlockSize",
        "hipModuleOccupancyMaxPotentialBlockSizeWithFlags",
        "hipModuleOccupancyMaxPotentialBlockSizeWithFlags"
    )
    {
        s{\b($func)\s*(\((?:[^()]+|(?2))*\))}{ $process_args->($1, $2, 3, 2, "") }ges;
    }
    foreach $func (
        "hipGraphExecMemcpyNodeSetParamsFromSymbol"
    )
    {
        s{\b($func)\s*(\((?:[^()]+|(?2))*\))}{ $process_args->($1, $2, 3, 0, "HIP_SYMBOL") }ges;
    }
    foreach $func (
        "hipGraphAddMemcpyNodeToSymbol"
    )
    {
        s{\b($func)\s*(\((?:[^()]+|(?2))*\))}{ $process_args->($1, $2, 4, 0, "HIP_SYMBOL") }ges;
    }
    foreach $func (
        "hipGraphAddMemcpyNodeFromSymbol"
    )
    {
        s{\b($func)\s*(\((?:[^()]+|(?2))*\))}{ $process_args->($1, $2, 5, 0, "HIP_SYMBOL") }ges;
    }
}

