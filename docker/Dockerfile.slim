# syntax=docker/dockerfile:1.6
# rocMolKit runtime slim — base ubuntu puro + pacotes ROCm seletivos via apt.
# NÃO usa rocm/dev-ubuntu (~13 GB). Usa ubuntu:22.04 (~30 MB) + apt selectivo.
#
# Build: docker build -f docker/Dockerfile.slim -t rocmolkit:slim .
# Run:   docker run --device=/dev/kfd --device=/dev/dri --group-add video rocmolkit:slim

ARG ROCM_VERSION=7.2.3
# Default targets cover RDNA4 (gfx1200/Navi 44 = RX 9060/9070), RDNA3 (gfx1100),
# CDNA2 (gfx90a / MI200), CDNA3 (gfx942 / MI300).
ARG GPU_TARGETS="gfx1200;gfx1100;gfx90a;gfx942"
ARG PYTHON_VERSION=3.11
ARG UBUNTU_CODENAME=jammy

# ─────────────────────────────────────────────────────────────
# STAGE 1: builder — ubuntu + ROCm SDK seletivo (~3–4 GB)
# ─────────────────────────────────────────────────────────────
FROM ubuntu:22.04 AS builder

ARG ROCM_VERSION
ARG GPU_TARGETS
ARG PYTHON_VERSION
ARG UBUNTU_CODENAME

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Adiciona repo AMD ROCm + instala SOMENTE o que precisa para compilar.
# rocm-hip-sdk = compilador hipcc + runtime + headers comuns.
# Se quiser mais enxuto: rocm-hip-runtime-dev + hipcc + rocblas-dev manualmente.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg lsb-release \
    && curl -fsSL https://repo.radeon.com/rocm/rocm.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/rocm.gpg \
    && echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/rocm.gpg] https://repo.radeon.com/rocm/apt/${ROCM_VERSION} ${UBUNTU_CODENAME} main" \
        > /etc/apt/sources.list.d/rocm.list \
    && printf 'Package: *\nPin: release o=repo.radeon.com\nPin-Priority: 600\n' \
        > /etc/apt/preferences.d/rocm-pin-600 \
    && apt-get update && apt-get install -y --no-install-recommends \
        build-essential ninja-build git \
        python${PYTHON_VERSION} python${PYTHON_VERSION}-dev python3-pip \
        libboost-all-dev libeigen3-dev zlib1g-dev libbz2-dev \
        libfreetype6-dev \
        hipcc hip-dev hip-runtime-amd \
        rocm-device-libs rocm-llvm \
        rocblas-dev hipblas-dev \
        rocrand-dev hiprand-dev \
        rocsolver-dev hipsolver-dev \
        hipcub-dev rocprim-dev rocthrust-dev \
    && rm -rf /var/lib/apt/lists/*

ENV PATH=/root/.local/bin:/opt/rocm/bin:$PATH \
    ROCM_PATH=/opt/rocm

# Python build tools via uv (no conda; runtime stage stays clean).
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
    && uv pip install --system --break-system-packages --no-cache-dir \
        cmake scikit-build-core nanobind numpy

# RDKit C++ from source - no PyPI wheel ships the headers and Ubuntu jammy's
# librdkit-dev is 5 years old (2021.09). This is in the BUILDER stage only,
# so the .so artifacts copy out but the toolchain (~3 GB of git/cmake/boost)
# is discarded with the stage.
COPY tools/build_rdkit.sh /tmp/build_rdkit.sh
RUN chmod +x /tmp/build_rdkit.sh && /tmp/build_rdkit.sh Release_2024_09_6
ENV RDKIT_ROOT=/opt/rdkit

WORKDIR /src
COPY . /src

RUN ROCM_PATH=$(ls -d /opt/rocm-* 2>/dev/null | head -1) \
    && ROCM_PATH=${ROCM_PATH:-/opt/rocm} \
    && ROCM_CLANG="$ROCM_PATH/llvm/bin/clang++" \
    && DEVICE_LIB=$(find "$ROCM_PATH/lib/llvm/lib/clang/"*/lib/amdgcn/bitcode -maxdepth 0 -type d 2>/dev/null | head -1) \
    && DEVICE_LIB=${DEVICE_LIB:-$ROCM_PATH/amdgcn/bitcode} \
    && HIP_FLAGS="--rocm-path=$ROCM_PATH --rocm-device-lib-path=$DEVICE_LIB" \
    && mkdir -p /install \
    && cmake -S . -B /build -GNinja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/install \
        -DCMAKE_CXX_COMPILER="$ROCM_CLANG" \
        -DCMAKE_HIP_COMPILER="$ROCM_CLANG" \
        -DCMAKE_HIP_PLATFORM=amd \
        -DCMAKE_HIP_FLAGS="$HIP_FLAGS" \
        -DCMAKE_HIP_FLAGS_INIT="$HIP_FLAGS" \
        -DROCM_PATH="$ROCM_PATH" \
        -DGPU_TARGETS="${GPU_TARGETS}" \
        -DRDKit_ROOT=${RDKIT_ROOT} \
        -DROCMOLKIT_BUILD_TESTS=OFF \
    && cmake --build /build --parallel \
    && cmake --install /build \
    && find /install -name '*.so*' -type f -exec strip --strip-unneeded {} + 2>/dev/null || true \
    && touch /install/.built

# ─────────────────────────────────────────────────────────────
# STAGE 2: runtime — ubuntu + ROCm runtime seletivo (~700 MB–1 GB)
# ─────────────────────────────────────────────────────────────
FROM ubuntu:22.04 AS runtime

ARG ROCM_VERSION
ARG PYTHON_VERSION
ARG UBUNTU_CODENAME
ARG GPU_TARGETS

ENV DEBIAN_FRONTEND=noninteractive \
    LD_LIBRARY_PATH=/opt/rocm/lib \
    PATH=/opt/rocm/bin:$PATH \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg \
    && curl -fsSL https://repo.radeon.com/rocm/rocm.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/rocm.gpg \
    && echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/rocm.gpg] https://repo.radeon.com/rocm/apt/${ROCM_VERSION} ${UBUNTU_CODENAME} main" \
        > /etc/apt/sources.list.d/rocm.list \
    && printf 'Package: *\nPin: release o=repo.radeon.com\nPin-Priority: 600\n' \
        > /etc/apt/preferences.d/rocm-pin-600 \
    && apt-get update && apt-get install -y --no-install-recommends \
        python${PYTHON_VERSION} python3-pip \
        libpython${PYTHON_VERSION} libstdc++6 libgomp1 libnuma1 libelf1 \
        libdrm2 libdrm-amdgpu1 \
        hip-runtime-amd hsa-rocr comgr \
        rocblas \
        rocrand hiprand \
    # Drop transitive heavy deps not used in Phase 1-5: rocsolver (1.7 GB),
    # rocsparse (1.4 GB), hipsolver/hipsparse. ETKDG/MMFF do not call them.
    # Use --auto-remove cautiously — explicit purge only.
    && apt-get purge -y --auto-remove \
        rocsolver rocsparse hipsolver hipsparse 2>/dev/null || true \
    && apt-get purge -y curl gnupg \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/* \
              /var/cache/apt/* \
              /usr/share/doc /usr/share/man /usr/share/locale \
              /opt/rocm/share \
              /opt/rocm/llvm/share /opt/rocm/llvm/include /opt/rocm/llvm/lib/clang/*/share \
              /opt/rocm/llvm/bin /opt/rocm/llvm/libexec \
              /opt/rocm/include /opt/rocm/bin/clang* \
              /opt/rocm/lib/cmake \
              /opt/rocm/lib/librocsolver* /opt/rocm/lib/librocsparse* \
              /opt/rocm/lib/libhipsolver* /opt/rocm/lib/libhipsparse* \
    # Tensile kernels: ROCm 6.2 layout uses
    #   /opt/rocm/lib/rocblas/library/Kernels.so-NNN-gfx*.hsaco
    #   /opt/rocm/lib/rocblas/library/TensileLibrary_*_gfx*.[dat|co]
    # Keep ONLY files that match one of the GPU_TARGETS arches. List first to
    # confirm pattern, then delete.
    && KEEP_PATTERN="$(echo "${GPU_TARGETS}" | sed 's/;/|/g')" \
    && echo "=== Tensile files BEFORE filter (sample) ===" \
    && ls /opt/rocm/lib/rocblas/library/ 2>/dev/null | head -10 \
    && echo "=== KEEP arches: ${KEEP_PATTERN} ===" \
    && find /opt/rocm/lib/rocblas/library -maxdepth 1 -type f \
        ! -regex ".*\(${KEEP_PATTERN}\).*" \
        -delete 2>/dev/null || true \
    && echo "=== Tensile files AFTER filter ===" \
    && du -sh /opt/rocm/lib/rocblas/ \
    && find / -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true

RUN python${PYTHON_VERSION} -m pip install --no-cache-dir numpy rdkit-pypi \
    && find / -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true \
    && find /opt/rocm -name '*.so*' -type f -exec strip --strip-unneeded {} + 2>/dev/null || true

COPY --from=builder /install /usr/local

# Diagnóstico de tamanho — aparece no log do build para guiar próximos cortes.
RUN echo "=== runtime image breakdown ===" \
    && du -sh /opt/rocm/* 2>/dev/null | sort -h | tail -15 \
    && echo "--- /opt/rocm/lib top ---" \
    && du -sh /opt/rocm/lib/* 2>/dev/null | sort -h | tail -15 \
    && echo "--- /usr/lib/python3 ---" \
    && du -sh /usr/lib/python3* 2>/dev/null | sort -h | tail -10 \
    && echo "--- /usr/local ---" \
    && du -sh /usr/local 2>/dev/null \
    && echo "--- TOTAL ---" \
    && du -sh / 2>/dev/null | tail -1

ENTRYPOINT ["python3"]
